PORT=5000

# Leave as-is for local dev (in-memory DB auto-starts).
# For Atlas: Atlas → your cluster → Connect → Drivers → copy connection string.
# Replace <password> and set your DB name, e.g.:
# MONGODB_URI=mongodb+srv://myuser:myPass@cluster0.xxxxx.mongodb.net/centerdesk?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/centerdesk

JWT_SECRET=change-me-to-a-long-random-string
CLIENT_URL=http://localhost:5173
NODE_ENV=development
